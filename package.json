{
  "name": "tsgo-ready",
  "version": "0.1.0",
  "description": "Scan your TypeScript repo for what the move to the native Go compiler (tsgo / TypeScript 7.0) breaks — removed tsconfig flags, Compiler-API-dependent tooling that needs TS 6 side-by-side, and decorator/JSDoc behavior changes. Deterministic CLI + GitHub Action, no LLM key.",
  "type": "module",
  "bin": {
    "tsgo-ready": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "action.yml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test --import tsx test/*.test.ts",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "demo": "node dist/cli.js --project test/fixtures/broken"
  },
  "keywords": [
    "typescript",
    "typescript-7",
    "tsgo",
    "typescript-go",
    "corsa",
    "migration",
    "readiness",
    "scanner",
    "tsconfig",
    "compiler-api",
    "decorators",
    "ci",
    "github-action",
    "lint"
  ],
  "author": "fernforge",
  "license": "MIT",
  "homepage": "https://github.com/fernforge/tsgo-ready#readme",
  "bugs": {
    "url": "https://github.com/fernforge/tsgo-ready/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fernforge/tsgo-ready.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
